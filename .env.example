# Server
PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Internal Auth — cnkb2b and cnk-website must send this in the x-api-key header
INTERNAL_API_KEY=your_internal_api_key_here

# Flight Provider — change these two lines to switch providers (tripjack | travclan | tbo)
FLIGHT_PROVIDER=tripjack
FLIGHT_API_KEY=your_flight_provider_api_key_here
FLIGHT_API_BASE_URL=https://apitest.tripjack.com

# Hotel — uses the same Supabase instance above (no extra config needed)

# Hotel Provider — TripJack hotel static APIs
# City sync, Search, Detail, Review, Nationality, Static Content (v3 production — confirmed by TripJack)
HOTEL_HMS_API_BASE_URL_LIVE=https://hms-search.tripjack.com
HOTEL_HMS_API_BASE_URL_TEST=https://apitest-hms.tripjack.com
# Hotel/static sync (v3 production — same domain as HMS per TripJack)
HOTEL_STATIC_API_BASE_URL_LIVE=https://hms-search.tripjack.com
HOTEL_STATIC_API_BASE_URL_TEST=https://apitest.tripjack.com
HOTEL_API_KEY=your_hotel_api_key_here

# Default API mode — set 'test' in dev/.env, 'live' in production
# Can be overridden per-request with ?mode=test or ?mode=live
HOTEL_MODE=test

# Hotel Booker — booking, booking-details, cancel-booking (v3 production — confirmed by TripJack)
HOTEL_BOOKER_API_BASE_URL_TEST=https://apitest-hotel-booker.tripjack.com
HOTEL_BOOKER_API_BASE_URL_LIVE=https://hms-booker.tripjack.com

# ICICI eCollections — virtual account payment callbacks
# Provided by ICICI during onboarding (leave blank until keys are received)
ICICI_PRIVATE_KEY=
ICICI_PUBLIC_CERT=
# Optional: comma-separated IPs to whitelist (leave blank to skip IP check)
ICICI_WHITELISTED_IPS=
