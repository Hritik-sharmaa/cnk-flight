# Server
PORT=3001
NODE_ENV=development

# Internal Auth — cnkb2b and cnk-website must send this in the x-api-key header
INTERNAL_API_KEY=your_internal_api_key_here

# Flight Provider — change these two lines to switch providers (tripjack | travclan | tbo)
FLIGHT_PROVIDER=tripjack
FLIGHT_API_KEY=your_flight_provider_api_key_here
FLIGHT_API_BASE_URL=https://apitest.tripjack.com

# Supabase (same project as cnkb2b)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
